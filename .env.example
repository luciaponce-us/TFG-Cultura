MONGO_USER=root
MONGO_PASS=root
MONGO_DB=mydatabase
# Opcional: para producción (Atlas), define la URI completa.
# Si se deja vacía, se construye automáticamente con MONGO_USER/MONGO_PASS/MONGO_DB.
MONGODB_URI=
