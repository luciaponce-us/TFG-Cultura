<configuration>

<!-- Appenders -->

    <!-- CONSOLE -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- FILE -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/app.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- USERS -->
    <appender name="USERS" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/users_activity.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/users_activity.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- SUGGESTIONS -->
    <appender name="SUGGESTIONS" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/suggestions_activity.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/suggestions_activity.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level - %msg%n</pattern>
        </encoder>
    </appender>


<!-- Loggers -->

    <logger name="appLogger" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="usersLogger" level="INFO" additivity="false">
        <appender-ref ref="USERS"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="suggestionsLogger" level="INFO" additivity="false">
        <appender-ref ref="SUGGESTIONS"/>
    </logger>

    <logger name="org.springframework" level="WARN"/>


    <root level="INFO">
        <appender-ref ref="FILE"/>
    </root>

</configuration>